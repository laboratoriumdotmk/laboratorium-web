# Database — PostgreSQL
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/laboratorium

# Payload
PAYLOAD_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Preview
PREVIEW_SECRET=change-me-preview-secret

# Cloudflare R2 / S3-compatible storage
# Leave all blank to fall back to local disk uploads/ (dev only)
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=laboratorium-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Public CDN URL for uploaded assets (e.g. https://media.laboratorium.mk)
NEXT_PUBLIC_CDN_URL=

# Email — choose one provider
# Option A: Resend (preferred)
RESEND_API_KEY=
# Option B: SMTP (used if RESEND_API_KEY is absent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Contact notifications destination
CONTACT_EMAIL=contact@laboratorium.mk

# Seed admin credentials (used by pnpm seed)
SEED_ADMIN_EMAIL=admin@laboratorium.mk
SEED_ADMIN_PASSWORD=changeme123

# Cron secret for scheduled jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Optional: Plausible analytics domain — leave blank to disable
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
